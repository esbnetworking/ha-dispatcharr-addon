#!/usr/bin/with-contenv bashio
cd /app
export PYTHONPATH="/app"
export PATH="/app/env/bin:$PATH"

# Load environment safely
set -a
. /app/.env
set +a

until /app/env/bin/python3 manage.py migrate --check >/dev/null 2>&1; do
  echo "Waiting for migrations..."
  sleep 2
done
exec /app/env/bin/python3 -m celery -A dispatcharr worker -l info --concurrency=1
